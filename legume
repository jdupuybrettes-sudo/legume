function bindAll(){document.querySelectorAll('[data-action]').forEach(el=>{el.onclick=actions[el.dataset.action]}); document.querySelectorAll('[data-bind]').forEach(el=>{el.onchange=(e)=>updateBind(el.dataset.bind,e.target.value); if(el.tagName==='INPUT'){el.oninput=(e)=>updateBind(el.dataset.bind,e.target.value,false); el.onkeydown=(e)=>{if(e.key==='Enter'){e.preventDefault(); e.target.blur();}};}});}
function updateBind(path,value,rer=true){setLastInput(path); let parts=path.split('.'); let obj=data; for(let i=0;i<parts.length-1;i++){let key=parts[i]; if(Array.isArray(obj)){obj=obj[Number(key)]}else obj=obj[key];} obj[parts[parts.length-1]]=value; if(path.includes('productId')){let idx=Number(parts[1]); let p=productById(value); if(p&&data.rows[idx])data.rows[idx].unit=p.unit;} save(); if(rer!==false)render();}
