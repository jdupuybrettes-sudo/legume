data.expenses.forEach((r,i)=>{let alert=expenseAlert(r); html+=`<div class="mobile-card${lastClass('expenses',i)}" data-last-key="${lastKey('expenses',i)}"><div class="mobile-card-title"><span>Frais n°${i+1}</span><span class="mobile-badge">${r.type?esc(r.type):'Type'}</span></div><div class="mobile-grid"><div class="mobile-field"><label>Date</label><input type="date" value="${esc(r.date||'')}" data-bind="expenses.${i}.date"></div><div class="mobile-field"><label>Type frais</label><select data-bind="expenses.${i}.type">${selectHTML(types,r.type,'Type')}</select></div><div class="mobile-field"><label>Dénomination</label><select data-bind="expenses.${i}.name">${selectHTML(expenseNames(r.type),r.name,'Dénomination')}</select></div><div class="mobile-grid two"><div class="mobile-field"><label>Magasin</label><select data-bind="expenses.${i}.shop">${selectHTML(SHOPS,r.shop,'Magasin')}</select></div><div class="mobile-field"><label>Montant €</label><input type="text" inputmode="decimal" autocomplete="off" value="${esc(r.amount||'')}" data-bind="expenses.${i}.amount"></div></div><div class="mobile-field auto"><label>Total frais ligne</label><div class="mobile-total">${euro(toNum(r.amount))}</div></div></div><div class="mobile-actions"><div class="mobile-alert ${alert?'bad':'ok'}">${alert?esc(alert):'OK'}</div><button class="red" onclick="window.appDelExpense(${i})">Supprimer</button></div></div>`;});
