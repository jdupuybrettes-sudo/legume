function renderSynthese(){let y=toNum(data.selectedYear); let weeks=Array.from({length:53},(_,i)=>i+1); let html=`<div class="card"><div class="section-title"><div><h2>Synthèse</h2><div class="note">Les pertes sont en information. Résultat simple = CA - achats - frais.</div></div><div><label>Année à analyser</label><select class="input-small" data-bind="selectedYear">${selectHTML(YEARS.map(String),String(data.selectedYear))}</select></div></div></div>`;
html+=`<div class="grid grid-2"><div class="card"><h2>Par semaine</h2><div class="table-wrap"><table><thead><tr><th>Semaine</th><th>Achats total</th><th>Achats Mag.1</th><th>Achats Mag.2</th><th>CA total</th><th>Pertes info</th><th>Écart CA - achats</th></tr></thead><tbody>`;
weeks.forEach(w=>{let s=mergeCA(summarizeRows(rowsByWeek(y,w)),summarizeCA(caRowsByWeek(y,w))); if(!(s.purchases||s.ca||s.loss))return; html+=`<tr><td class="center">${w}</td><td class="num">${euro(s.purchases)}</td><td class="num">${euro(s.achatM1)}</td><td class="num">${euro(s.achatM2)}</td><td class="num ca-cell">${euro(s.ca)}</td><td class="num loss-cell">${euro(s.loss)}</td><td class="num ${(s.ca-s.purchases)<0?'neg':'pos'}">${euro(s.ca-s.purchases)}</td></tr>`});
html+=`</tbody></table></div></div><div class="card"><h2>Par mois</h2><div class="table-wrap"><table><thead><tr><th>Mois</th><th>Achats total</th><th>Achats Mag.1</th><th>Achats Mag.2</th><th>CA total</th><th>Pertes info</th><th>Écart CA - achats</th></tr></thead><tbody>`;
let tot={p:0,m1:0,m2:0,ca:0,loss:0}; for(let m=1;m<=12;m++){let s=mergeCA(summarizeRows(rowsByMonth(y,m)),summarizeCA(caRowsByMonth(y,m))); tot.p+=s.purchases; tot.m1+=s.achatM1; tot.m2+=s.achatM2; tot.ca+=s.ca; tot.loss+=s.loss; html+=`<tr><td>${monthName(m)}</td><td class="num">${euro(s.purchases)}</td><td class="num">${euro(s.achatM1)}</td><td class="num">${euro(s.achatM2)}</td><td class="num ca-cell">${euro(s.ca)}</td><td class="num loss-cell">${euro(s.loss)}</td><td class="num ${(s.ca-s.purchases)<0?'neg':'pos'}">${euro(s.ca-s.purchases)}</td></tr>`}
html+=`<tr><th>TOTAL ANNÉE</th><th class="num">${euro(tot.p)}</th><th class="num">${euro(tot.m1)}</th><th class="num">${euro(tot.m2)}</th><th class="num">${euro(tot.ca)}</th><th class="num">${euro(tot.loss)}</th><th class="num ${(tot.ca-tot.p)<0?'neg':'pos'}">${euro(tot.ca-tot.p)}</th></tr>`;
html+=`</tbody></table></div></div></div>`; document.getElementById('synthese').innerHTML=html;}
function renderBases(){let html=`<div class="grid grid-3"><div class="card"><div class="section-title"><h2>Base produits</h2><button class="green" data-action="addProduct">+ Produit</button></div><div class="table-wrap tall"><table><thead><tr><th>Produit</th><th>Unité</th><th>% perte</th><th></th></tr></thead><tbody>`;
sortedProducts().forEach(p=>{let i=data.products.findIndex(x=>x.id===p.id); html+=`<tr><td class="input-cell"><input value="${esc(p.name)}" data-bind="products.${i}.name"></td><td class="input-cell"><select data-bind="products.${i}.unit">${selectHTML(UNITS,p.unit,'Unité')}</select></td><td class="input-cell"><input type="text" inputmode="decimal" autocomplete="off" value="${esc(p.lossPct)}" data-bind="products.${i}.lossPct"></td><td><button class="red mini" onclick="window.appDelProduct(${i})">X</button></td></tr>`});
html+=`</tbody></table></div></div><div class="card"><div class="section-title"><h2>Base fournisseurs</h2><button class="green" data-action="addSupplier">+ Fournisseur</button></div><div class="table-wrap tall"><table><thead><tr><th>Fournisseur</th><th></th></tr></thead><tbody>`;
suppliersOptions().forEach(s=>{let i=data.suppliers.findIndex(x=>x.id===s.id); html+=`<tr><td class="input-cell"><input value="${esc(s.name)}" data-bind="suppliers.${i}.name"></td><td><button class="red mini" onclick="window.appDelSupplier(${i})">X</button></td></tr>`});
html+=`</tbody></table></div></div><div class="card"><div class="section-title"><h2>Base frais</h2><button class="green" data-action="addExpenseBase">+ Frais</button></div><div class="table-wrap tall"><table><thead><tr><th>Type</th><th>Dénomination</th><th>Magasin défaut</th><th></th></tr></thead><tbody>`;
data.expensesBase.forEach((e,i)=>{html+=`<tr><td class="input-cell"><input value="${esc(e.type)}" data-bind="expensesBase.${i}.type"></td><td class="input-cell"><input value="${esc(e.name)}" data-bind="expensesBase.${i}.name"></td><td class="input-cell"><select data-bind="expensesBase.${i}.shop">${selectHTML(SHOPS,e.shop,'Magasin')}</select></td><td><button class="red mini" onclick="window.appDelExpenseBase(${i})">X</button></td></tr>`});
html+=`</tbody></table></div></div></div>`; document.getElementById('bases').innerHTML=html;}
function renderControles(){let alerts=[]; data.rows.forEach((r,i)=>{let a=rowAlert(r,i); if(a)alerts.push({page:'Saisie achats',line:i+1,msg:a});}); (data.caRows||[]).forEach((r,i)=>{let a=caAlert(r); if(a)alerts.push({page:'Saisie CA',line:i+1,msg:a});}); data.expenses.forEach((r,i)=>{let a=expenseAlert(r); if(a)alerts.push({page:'Saisie frais',line:i+1,msg:a});}); let stock=stockByProductUntil(`${data.selectedYear}-12-31`).filter(s=>s.stockQty<0); stock.forEach(s=>alerts.push({page:'Décompte stock',line:'-',msg:`Stock dépôt négatif : ${s.product.name}`}));
let html=`<div class="card"><h2>Contrôles</h2>${alerts.length?`<div class="danger-note">${alerts.length} alerte(s) à vérifier.</div>`:`<div class="success-note">Aucune alerte détectée.</div>`}<div class="table-wrap" style="margin-top:12px"><table><thead><tr><th>Page</th><th>Ligne</th><th>Problème</th></tr></thead><tbody>`;
html+=alerts.map(a=>`<tr><td>${esc(a.page)}</td><td class="center">${esc(a.line)}</td><td class="bad">${esc(a.msg)}</td></tr>`).join('')||`<tr><td colspan="3" class="center muted">Tout est OK.</td></tr>`;
html+=`</tbody></table></div></div>`; document.getElementById('controles').innerHTML=html;}
function renderSauvegarde(){let html=`<div class="card"><h2>Sauvegarde / export</h2><p class="note">Les données sont sauvegardées automatiquement sur ce PC dans le navigateur. Pour sécuriser le travail, exporte régulièrement une sauvegarde JSON.</p><div class="toolbar"><button class="blue" data-action="exportJSON">Exporter sauvegarde JSON</button><button class="green" data-action="exportExcel">Exporter Excel (.xls)</button><button class="secondary" data-action="importJSON">Importer JSON</button><button class="red" data-action="resetAll">Réinitialiser</button></div><input id="importFile" class="hidden" type="file" accept="application/json,.json"></div><div class="card"><h2>Mode emploi rapide</h2><ol class="note"><li>Saisie achats : remplir achats et déstock.</li><li>Saisie frais : remplir loyer, gazoil, frais annexes.</li><li>Saisie CA : remplir CA Mag.1 et CA Mag.2 dans l’onglet dédié.</li><li>Bases : ajouter produits, fournisseurs et frais.</li><li>Décompte stock : contrôler le stock dépôt.</li><li>Tableau résultat : consulter CA, achats, frais, pertes info, stock dépôt et résultat.</li><li>L’année active se change en haut de l’application et s’applique à toutes les pages.</li><li>Les couleurs du menu indiquent le type de page : vert = saisie/base, orange = information/contrôle, bleu = résultat.</li><li>Les calculs se recalculent automatiquement après la saisie. La dernière ligne modifiée reste mémorisée et encadrée en bleu pour la retrouver facilement.</li></ol></div>`; document.getElementById('sauvegarde').innerHTML=html;}
function rowAlert(r,i){if(!hasMovement(r))return ''; let hasQty=rowPurchaseQty(r)||toNum(r.destockM1)||toNum(r.destockM2); if(!r.date)return 'Date manquante'; if(hasQty&&!r.productId)return 'Produit manquant'; if(hasQty&&!r.unit)return 'Unité manquante'; if(rowPurchaseQty(r)&&!r.supplierId)return 'Fournisseur manquant'; if(rowPurchaseQty(r)&&!toNum(r.price))return 'Prix achat manquant'; if((toNum(r.destockM1)||toNum(r.destockM2))&&!r.productId)return 'Produit déstock manquant'; return '';}
function caAlert(r){let used=!!(r.date||toNum(r.caM1)||toNum(r.caM2)||r.note); if(!used)return ''; if(!r.date)return 'Date CA manquante'; if(!toNum(r.caM1)&&!toNum(r.caM2))return 'Montant CA manquant'; return '';}
function expenseAlert(r){let used=!!(r.date||r.type||r.name||r.shop||toNum(r.amount)); if(!used)return ''; if(!r.date)return 'Date manquante'; if(!r.type)return 'Type frais manquant'; if(!r.name)return 'Dénomination manquante'; if(!r.shop)return 'Magasin manquant'; if(!toNum(r.amount))return 'Montant manquant'; return '';}
const actions={
  addRow(){data.rows.push({id:uid(),date:dateISO(),productId:'',supplierId:'',unit:'',purchaseDepot:'',purchaseM1:'',purchaseM2:'',price:'',destockM1:'',destockM2:''}); setLastInput('rows.'+(data.rows.length-1)+'.date'); currentTab='saisie'; render()},
  add10Rows(){let start=data.rows.length; for(let i=0;i<10;i++)data.rows.push({id:uid(),date:dateISO(),productId:'',supplierId:'',unit:'',purchaseDepot:'',purchaseM1:'',purchaseM2:'',price:'',destockM1:'',destockM2:''}); setLastInput('rows.'+start+'.date'); currentTab='saisie'; render()},
  addCA(){data.caRows=data.caRows||[]; data.caRows.push({id:uid(),date:dateISO(),caM1:'',caM2:'',note:''}); setLastInput('caRows.'+(data.caRows.length-1)+'.date'); currentTab='ca'; render()},
  add5CA(){data.caRows=data.caRows||[]; let start=data.caRows.length; for(let i=0;i<5;i++)data.caRows.push({id:uid(),date:dateISO(),caM1:'',caM2:'',note:''}); setLastInput('caRows.'+start+'.date'); currentTab='ca'; render()},
  addExpense(){data.expenses.push({id:uid(),date:dateISO(),type:'',name:'',shop:'',amount:''}); setLastInput('expenses.'+(data.expenses.length-1)+'.date'); currentTab='frais'; render()},
  add5Expenses(){let start=data.expenses.length; for(let i=0;i<5;i++)data.expenses.push({id:uid(),date:dateISO(),type:'',name:'',shop:'',amount:''}); setLastInput('expenses.'+start+'.date'); currentTab='frais'; render()},
  addProduct(){data.products.push({id:uid(),name:'Nouveau produit',unit:'kg',lossPct:10});render()},
  addSupplier(){data.suppliers.push({id:uid(),name:'Nouveau fournisseur'});render()},
  addExpenseBase(){data.expensesBase.push({id:uid(),type:'Frais annexe',name:'Nouveau frais',shop:'Commun'});render()},
  exportJSON(){download('sauvegarde_gestion_fruits_legumes.json',JSON.stringify(data,null,2),'application/json')},
  importJSON(){let input=document.getElementById('importFile'); input.onchange=e=>{let f=e.target.files[0]; if(!f)return; let rd=new FileReader(); rd.onload=()=>{try{let d=JSON.parse(rd.result); if(!d.products||!d.rows)throw new Error('Fichier non valide'); d.caRows=d.caRows||[]; data=d; save(); render(); alert('Import terminé');}catch(err){alert('Import impossible : '+err.message)}}; rd.readAsText(f)}; input.click();},
  resetAll(){if(confirm('Réinitialiser toutes les données ?')){data=defaultData();save();render();}},
  exportExcel(){download('export_gestion_fruits_legumes.xls',buildExcelXml(),'application/vnd.ms-excel')}
};
window.appDelRow=i=>{if(confirm('Supprimer cette ligne ?')){data.rows.splice(i,1); if(uiState.lastInput&&uiState.lastInput.type==='rows'){uiState.lastInput.index=Math.max(0,Math.min(uiState.lastInput.index,data.rows.length-1));saveUI();} render();}};
window.appDelCA=i=>{if(confirm('Supprimer cette ligne CA ?')){data.caRows.splice(i,1); if(uiState.lastInput&&uiState.lastInput.type==='caRows'){uiState.lastInput.index=Math.max(0,Math.min(uiState.lastInput.index,data.caRows.length-1));saveUI();} render();}};
window.appDelExpense=i=>{data.expenses.splice(i,1); if(uiState.lastInput&&uiState.lastInput.type==='expenses'){uiState.lastInput.index=Math.max(0,Math.min(uiState.lastInput.index,data.expenses.length-1));saveUI();} render();};
window.appDelProduct=i=>{data.products.splice(i,1);render();};
window.appDelSupplier=i=>{data.suppliers.splice(i,1);render();};
window.appDelExpenseBase=i=>{data.expensesBase.splice(i,1);render();};
function download(name,content,type){let blob=new Blob([content],{type}); let a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=name; document.body.appendChild(a); a.click(); setTimeout(()=>{URL.revokeObjectURL(a.href);a.remove()},1000)}
function buildExcelXml(){let y=toNum(data.selectedYear); function sheet(name,headers,rows){let xml=`<Worksheet ss:Name="${escXml(name)}"><Table>`; xml+=`<Row>`+headers.map(h=>`<Cell><Data ss:Type="String">${escXml(h)}</Data></Cell>`).join('')+`</Row>`; rows.forEach(r=>{xml+=`<Row>`+r.map(c=>`<Cell><Data ss:Type="${typeof c==='number'?'Number':'String'}">${escXml(c)}</Data></Cell>`).join('')+`</Row>`}); return xml+`</Table></Worksheet>`}
let saisie=data.rows.map(r=>[dateFR(r.date),productById(r.productId)?.name||'',data.suppliers.find(s=>s.id===r.supplierId)?.name||'',r.unit,toNum(r.purchaseDepot),toNum(r.purchaseM1),toNum(r.purchaseM2),toNum(r.price),toNum(r.destockM1),toNum(r.destockM2),rowPurchaseValue(r),rowLossValue(r)]);
let ca=(data.caRows||[]).map(r=>[dateFR(r.date),toNum(r.caM1),toNum(r.caM2),toNum(r.caM1)+toNum(r.caM2),r.note||'']);
let frais=data.expenses.map(r=>[dateFR(r.date),r.type,r.name,r.shop,toNum(r.amount)]);
let stock=stockByProductUntil(`${y}-12-31`).map(s=>[s.product.name,s.product.unit,s.purchaseDepotQty,s.purchaseDepotValue,s.avg,s.destockM1,s.destockM2,s.stockQty,s.stockValue]);
let result=[]; for(let m=1;m<=12;m++){let r=resultObj(rowsByMonth(y,m),expensesByMonth(y,m),caRowsByMonth(y,m)); result.push([monthName(m),r.ca,r.purchases,r.frais.total,r.totalExpenses,r.loss,r.result,r.resultAfterLoss]);}
return `<?xml version="1.0"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">`+
 sheet('Saisie marchandises',['Date','Produit','Fournisseur','Unité','Achat Dépôt','Achat Mag1','Achat Mag2','Prix','Déstock M1','Déstock M2','Total achat','Pertes info'],saisie)+
 sheet('CA',['Date','CA Mag1','CA Mag2','Total CA','Note'],ca)+
 sheet('Frais',['Date','Type','Dénomination','Magasin','Montant'],frais)+
 sheet('Stock dépôt',['Produit','Unité','Achat dépôt','Valeur achat dépôt','Prix moyen','Déstock M1','Déstock M2','Stock dépôt','Valeur stock'],stock)+
 sheet('Résultat mois',['Mois','CA','Achats','Frais','Dépenses globales','Pertes info','Résultat simple','Résultat après pertes'],result)+`</Workbook>`}
function escXml(s){return String(s??'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]));}
render();
})();
