function renderStock(){let y=toNum(data.selectedYear); let stock=stockByProductUntil(`${y}-12-31`); let html=`<div class="card"><div class="section-title"><div><h2>Décompte stock dépôt</h2><div class="note">Valorisation du stock dépôt au prix moyen pondéré des achats dépôt. Les pertes restent un indicateur séparé.</div></div><div><span class="pill">Année ${y}</span></div></div><div class="table-wrap"><table><thead><tr><th>Produit</th><th>Unité</th><th>Achat dépôt</th><th>Valeur achat dépôt</th><th>Prix moyen</th><th>Déstock M1</th><th>Déstock M2</th><th>Stock dépôt restant</th><th>Valeur stock dépôt</th><th>% perte</th><th>Statut</th></tr></thead><tbody>`;
